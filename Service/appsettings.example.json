{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5001"
    ]
  },
  "Configuration": {
    "_comment": "Hardening allowlist for code-loading config (PickingPostProcessing). Format: 'AssemblyFileName|FullTypeName'. When non-empty it is ENFORCED: only listed assembly/type pairs may be loaded or saved via the config API. Leave empty to permit any (a warning is logged).",
    "AssemblyAllowlist": [
      "Customer.Extensions.dll|Customer.Extensions.PackagingCalculatorPostProcessor"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft": "Error",
      "Microsoft.Hosting.Lifetime": "Error"
    }
  },
  "AllowedHosts": "*",
